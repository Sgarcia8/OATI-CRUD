{
    "swagger": "2.0",
    "info": {
        "title": "OATI CRUD API",
        "description": "API REST para gestión de tutoriales y comentarios\n",
        "version": "1.0.0",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "email": "sjgarciat8@gmail.com"
        }
    },
    "basePath": "/api/v1",
    "paths": {
        "/comments/{id}": {
            "put": {
                "tags": [
                    "oati-crud-comentarios/controllersCommentController"
                ],
                "description": "Actualiza el contenido de un comentario\n\u003cbr\u003e",
                "operationId": "CommentController.Actualizar comentario",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "description": "ID del comentario",
                        "required": true,
                        "type": "integer",
                        "format": "int64"
                    },
                    {
                        "in": "body",
                        "name": "body",
                        "description": "Datos del comentario",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dtos.UpdateCommentRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/dtos.CommentResponse"
                        }
                    },
                    "400": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "404": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            },
            "delete": {
                "tags": [
                    "oati-crud-comentarios/controllersCommentController"
                ],
                "description": "Elimina un comentario por ID\n\u003cbr\u003e",
                "operationId": "CommentController.Eliminar comentario",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "description": "ID del comentario",
                        "required": true,
                        "type": "integer",
                        "format": "int64"
                    }
                ],
                "responses": {
                    "204": {
                        "description": "\"No Content\""
                    },
                    "400": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "404": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            }
        },
        "/tutorials": {
            "get": {
                "tags": [
                    "oati-crud-comentarios/controllersTutorialController"
                ],
                "description": "Obtiene todos los tutoriales sin comentarios anidados\n\u003cbr\u003e",
                "operationId": "TutorialController.Listar tutoriales",
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/dtos.TutorialListResponse"
                        }
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            },
            "post": {
                "tags": [
                    "oati-crud-comentarios/controllersTutorialController"
                ],
                "description": "Crea un nuevo tutorial. published_at debe estar en formato RFC3339 (ej: 2026-06-18T00:00:00Z)\n\u003cbr\u003e",
                "operationId": "TutorialController.Crear tutorial",
                "parameters": [
                    {
                        "in": "body",
                        "name": "body",
                        "description": "Datos del tutorial",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dtos.CreateTutorialRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/dtos.TutorialResponse"
                        }
                    },
                    "400": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            }
        },
        "/tutorials/{id}": {
            "get": {
                "tags": [
                    "oati-crud-comentarios/controllersTutorialController"
                ],
                "description": "Obtiene un tutorial por ID con sus comentarios anidados\n\u003cbr\u003e",
                "operationId": "TutorialController.Obtener tutorial",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "description": "ID del tutorial",
                        "required": true,
                        "type": "integer",
                        "format": "int64"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/dtos.TutorialDetailResponse"
                        }
                    },
                    "400": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "404": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            },
            "put": {
                "tags": [
                    "oati-crud-comentarios/controllersTutorialController"
                ],
                "description": "Actualiza un tutorial existente\n\u003cbr\u003e",
                "operationId": "TutorialController.Actualizar tutorial",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "description": "ID del tutorial",
                        "required": true,
                        "type": "integer",
                        "format": "int64"
                    },
                    {
                        "in": "body",
                        "name": "body",
                        "description": "Datos del tutorial",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dtos.UpdateTutorialRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/dtos.TutorialResponse"
                        }
                    },
                    "400": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "404": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            },
            "delete": {
                "tags": [
                    "oati-crud-comentarios/controllersTutorialController"
                ],
                "description": "Elimina un tutorial y sus comentarios asociados\n\u003cbr\u003e",
                "operationId": "TutorialController.Eliminar tutorial",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "description": "ID del tutorial",
                        "required": true,
                        "type": "integer",
                        "format": "int64"
                    }
                ],
                "responses": {
                    "204": {
                        "description": "\"No Content\""
                    },
                    "400": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "404": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            }
        },
        "/tutorials/{tutorialId}/comments": {
            "get": {
                "tags": [
                    "oati-crud-comentarios/controllersCommentController"
                ],
                "description": "Obtiene todos los comentarios de un tutorial\n\u003cbr\u003e",
                "operationId": "CommentController.Listar comentarios de un tutorial",
                "parameters": [
                    {
                        "in": "path",
                        "name": "tutorialId",
                        "description": "ID del tutorial",
                        "required": true,
                        "type": "integer",
                        "format": "int64"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/dtos.CommentListResponse"
                        }
                    },
                    "400": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "404": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            },
            "post": {
                "tags": [
                    "oati-crud-comentarios/controllersCommentController"
                ],
                "description": "Crea un comentario asociado a un tutorial\n\u003cbr\u003e",
                "operationId": "CommentController.Crear comentario",
                "parameters": [
                    {
                        "in": "path",
                        "name": "tutorialId",
                        "description": "ID del tutorial",
                        "required": true,
                        "type": "integer",
                        "format": "int64"
                    },
                    {
                        "in": "body",
                        "name": "body",
                        "description": "Datos del comentario",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dtos.CreateCommentRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/dtos.CommentResponse"
                        }
                    },
                    "400": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "404": {
                        "description": "{object} dtos.ErrorResponse"
                    },
                    "500": {
                        "description": "{object} dtos.ErrorResponse"
                    }
                }
            }
        }
    },
    "definitions": {

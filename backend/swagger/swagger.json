            "title": "CommentResponse",
            "type": "object",
            "properties": {
                "content": {
                    "description": "Contenido del comentario",
                    "type": "string",
                    "example": "Comentario de prueba"
                },
                "created_at": {
                    "description": "Fecha de creación del comentario",
                    "type": "string",
                    "example": "2026-06-18T00:00:00Z",
                    "format": "datetime"
                },
                "id": {
                    "type": "integer",
                    "format": "int64"
                },
                "tutorial_id": {
                    "description": "ID del tutorial",
                    "type": "integer",
                    "example": 1,
                    "format": "int64"
                },
                "updated_at": {
                    "description": "Fecha de actualización del comentario",
                    "type": "string",
                    "example": "2026-06-18T00:00:00Z",
                    "format": "datetime"
